generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(uuid())
  email         String?     @unique
  phone         String?     @unique
  passwordHash  String
  createdAt     DateTime    @default(now())
  profile       Profile?
  preferences   Preference?
  matches1      Match[]     @relation("user1")
  matches2      Match[]     @relation("user2")
  likesGiven    Like[]      @relation("likes_given")
  likesReceived Like[]      @relation("likes_received")
  chatsSent     Chat[]      @relation("chats_sent")
  chatsReceived Chat[]      @relation("chats_received")
}

model Profile {
  id                String    @id @default(uuid())
  userId            String    @unique
  name              String
  dob               DateTime
  gender            String
  bio               String?
  hometown          String?
  religion          String?
  occupation        String?
  datingType        String?
  latitude          Float?
  longitude         Float?
  locationUpdatedAt DateTime?
  geohash           String?
  bloomFilter       String    @default("")
  age               Int?
  photos            Photo[]
  prompts           Prompt[]
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([geohash])
}

model Photo {
  id        String  @id @default(uuid())
  profileId String
  url       String
  s3Key     String?
  order     Int
  isPrimary Boolean @default(false)
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  likes     Like[]
}

model Prompt {
  id        String  @id @default(uuid())
  profileId String
  question  String
  answer    String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  likes     Like[]
}

model Preference {
  id          String @id @default(uuid())
  userId      String @unique
  minAge      Int    @default(18)
  maxAge      Int    @default(50)
  gender      String @default("any")
  maxDistance Int    @default(100)
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(uuid())
  likedById String
  likedToId String
  photoId   String?
  promptId  String?
  comment   String   @default("")
  createdAt DateTime @default(now())

  likedBy User    @relation("likes_given",    fields: [likedById], references: [id])
  likedTo User    @relation("likes_received", fields: [likedToId], references: [id])
  photo   Photo?  @relation(fields: [photoId],  references: [id])
  prompt  Prompt? @relation(fields: [promptId], references: [id])

  @@unique([likedById, likedToId])
}

model Match {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  matchedAt DateTime @default(now())
  isActive  Boolean  @default(true)
  user1     User     @relation("user1", fields: [user1Id], references: [id])
  user2     User     @relation("user2", fields: [user2Id], references: [id])

  @@unique([user1Id, user2Id])
}

model Chat {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  message    String
  createdAt  DateTime @default(now())

  sender   User @relation("chats_sent",     fields: [senderId],   references: [id])
  receiver User @relation("chats_received", fields: [receiverId], references: [id])
}
