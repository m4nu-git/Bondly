# iOS Simulator: localhost works
# Android Emulator: replace localhost with 10.0.2.2
# Real device: replace localhost with your machine's LAN IP (e.g. 192.168.1.X)
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_WS_URL=ws://localhost:3000

# Cloudinary (active — fill in from your Cloudinary dashboard)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
